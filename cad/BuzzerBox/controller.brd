<package name="USB-A-S-SILK-FEMALE" urn="urn:adsk.eagle:footprint:37979/1" locally_modified="yes">
<description>&lt;h3&gt;USB Type 'A' Female Connector - SMT Silk Outline&lt;/h3&gt;
